{
  "name": "portifolio-lucas-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node --input-type=module -e \"import { copyFileSync } from 'node:fs'; copyFileSync('index.dev.html','index.html')\"",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prebuild:pages": "node --input-type=module -e \"import { copyFileSync } from 'node:fs'; copyFileSync('index.dev.html','index.html')\"",
    "build:pages": "tsc -b && vite build --base=/lucasweb-portfolio/",
    "publish:pages": "npm run build:pages && node scripts/publish-root.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
